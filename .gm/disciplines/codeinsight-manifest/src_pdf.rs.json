ext(\"create pdfium.dll failed\")?;\n            io::copy(&mut entry, &mut out).context(\"extract pdfium.dll failed\")?;\n            extracted = true;\n            break;\n        }\n    }\n\n    let _ = std::fs::remove_file(&temp_path);\n\n    if !extracted {\n        anyhow::bail!(\"pdfium.dll not found in downloaded archive\");\n    }\n\n    Ok(dll_path)\n}","emb":[-0.08362357318401337,0.02435065619647503,0.027010561898350716,0.02351560816168785,0.04761379957199097,0.01082768663764,-0.10256702452898026,0.0844929963350296,-0.03494739532470703,-0.023293299600481987,-0.054999250918626785,-0.08849215507507324,0.023532958701252937,0.029112469404935837,-0.029200760647654533,-0.007155345752835274,0.000741941446904093,0.07394275814294815,-0.019046079367399216,0.03186773136258125,0.03646363690495491,-0.03648136556148529,0.06431250274181366,-0.0821976363658905,-0.027728082612156868,0.06934449076652527,-0.0178204458206892,-0.04915516451001167,-0.024885911494493484,-0.17579232156276703,-0.0565585158765316,-0.07119138538837433,-0.05058414489030838,-0.06270983070135117,0.036775968968868256,-0.03862055018544197,0.012451356276869774,0.008953755721449852,-0.02575800009071827,-0.004537399858236313,0.014086333103477955,0.11020565778017044,-0.06997715681791306,-0.06490309536457062,0.006278231739997864,-0.029435547068715096,0.017849251627922058,0.014202366583049297,0.057116732001304626,-0.015632085502147675,-0.07192131876945496,0.060909926891326904,0.06127230450510979,0.007697218097746372,-0.0648726373910904,0.08968034386634827,0.10405457019805908,0.11290483921766281,0.00260258954949677,0.037980224937200546,0.004956210497766733,0.01626063697040081,-0.13688457012176514,0.10341723263263702,0.041774898767471313,0.03015628084540367,-0.04691664129495621,-0.019114084541797638,0.008784533478319645,0.0069570294581353664,-0.028422335162758827,0.019921505823731422,0.01285660732537508,0.08846288919448853,0.05113513767719269,-0.009352706372737885,0.003783976659178734,-0.028653135523200035,-0.02